# Скопируй в .env и заполни своими значениями. .env в git не коммитим.

# === Базовая конфигурация ===
# Какой LLM-провайдер использовать: gigachat | yandex | mock
LLM_PROVIDER=gigachat
EMBEDDING_PROVIDER=gigachat

# Путь к базе знаний (по умолчанию — симлинк в data/knowledge_base)
KB_PATH=data/knowledge_base

# Путь к локальной ChromaDB
CHROMA_PATH=data/chroma

# === GigaChat ===
# Получить в личном кабинете developers.sber.ru/portal/products/gigachat-api
# Authorization key (base64) — длинная строка из ЛК
GIGACHAT_CREDENTIALS=
# Scope: GIGACHAT_API_PERS (физлицо) | GIGACHAT_API_B2B | GIGACHAT_API_CORP
GIGACHAT_SCOPE=GIGACHAT_API_PERS
# Модель LLM
GIGACHAT_MODEL=GigaChat
# Модель эмбеддингов
GIGACHAT_EMBEDDING_MODEL=Embeddings

# === YandexGPT (заполнить, когда придут ключи) ===
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_MODEL=yandexgpt-lite
YANDEX_EMBEDDING_MODEL=text-search-doc

# === Retrieval ===
TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.3
